nextflow.enable.dsl = 2

manifest {
    name            = 'pfNextflow'
    description     = 'Plasmodium falciparum analysis pipeline (Docker Offline)'
    mainScript      = 'main.nf'
    version         = '1.0.0'
    nextflowVersion = '>=22.0'
}

// ==================== DEFAULT PARAMETERS ====================
params {
    // Paths - resolved relative to project directory
    bam_root        = "${projectDir}/results/alignment/minimap2"
    bam_glob        = '*.bam'
    fastq_root      = "${projectDir}/data"
    fastq_glob      = 'barcode*/*.fastq.gz'
    outdir          = "${projectDir}/results"

    // References (relative to projectDir, resolved in main.nf)
    bed             = null
    ref             = null

    // iVar
    ivar_threshold    = 0.6
    ivar_min_cons_cov = 10
    ivar_min_var_cov  = 1
    genes             = 'CRT DHFR DHPS K13 MDR1 MSP2 PMI PMIII'

    // Minimap2
    minimap2_preset  = 'map-ont'
    minimap2_threads = 4

    // Bcftools
    variant_method   = 'bcftools'
    bcftools_mode    = 'mv'
    snp_only         = true
    bcftools_threads = 4
    max_depth        = 10000

    // AF/DP Figures
    afdp_min_depth    = 15
    afdp_af_threshold = 0.50
    afdp_shade_xmin   = 0.48
    afdp_shade_xmax   = 0.52

    // VCF
    vcf_glob = null

    // Pipeline toggles
    do_fastqc     = false
    do_alignment  = true
    do_depth      = true
    do_ivar       = true
    do_gene_bins  = true
    do_variants   = true
    do_multipanel = false
    do_gene_1x8   = false
    do_afdp       = true
    do_translate  = false   // CDS splice + translate + per-gene MSA + variant table
    do_resistance = false   // known drug resistance marker summary table

    // Resources
    max_cpus   = 32
    max_memory = '128.GB'
    max_time   = '240.h'
}

// ==================== EXECUTION PROFILES ====================
profiles {
    // Standard local profile - tools installed locally (DEFAULT)
    standard {
        process.executor = 'local'
    }

    // Local execution profile - alias
    local {
        process.executor = 'local'
    }

    // Docker profile (containers)
    docker {
        docker.enabled = true
        docker.runOptions = '--rm'
        
        process {
            container = 'biocontainers/samtools:latest'
            
            withName: 'FASTQ_QC' {
                container = 'biocontainers/fastqc:v0.12.1-1-deb_cv1'
                cpus      = 2
                memory    = 4.GB
                time      = 2.h
            }
            
            withName: 'MINIMAP2_ALIGN' {
                container = 'biocontainers/minimap2:v2.24-1-deb_cv1'
                cpus      = 4
                memory    = 8.GB
                time      = 4.h
            }
            
            withName: 'IVAR_CONSENSUS' {
                container = 'andersenlabapps/ivar:latest'
                cpus      = 2
                memory    = 4.GB
            }
            
            withName: 'CALL_VARIANTS' {
                container = 'biocontainers/bcftools:v1.17-1-deb_cv1'
                cpus      = 4
                memory    = 8.GB
            }
            
            withName: 'PF_DEPTH|GENE_BIN_DEPTH' {
                container = 'biocontainers/bedtools:v2.31.0-1-deb_cv1'
                cpus      = 2
                memory    = 4.GB
            }
            
            withName: 'PLOT_GENE_MULTIPANEL|PLOT_GENE_1x8|AF_DP_FIGURES' {
                container = 'rocker/r-base:4.3.1'
                cpus      = 2
                memory    = 4.GB
            }
            
            errorStrategy = { task.exitStatus in [1,143,137,104,134,139] ? 'retry' : 'finish' }
            maxRetries    = 2
        }
        
        // Docker pull을 위한 timeout 설정 (오프라인 모드에서 미리 pull 필요)
        docker.pullTimeout = '20 min'
    }
    
    // SLURM cluster execution profile
    slurm {
        process.executor = 'slurm'
        process.queue = 'default'
    }
}

// ==================== REPORT GENERATION ====================
timeline {
    enabled   = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/report.html"
}
